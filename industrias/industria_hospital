  "formulaPrincipal": "function(p,s,ctx){var rot=365/Math.max(p.estancia,0.5);var egrBase=Math.round(s.camas*(p.ocupacion/100)*rot);var cong=p.ocupacion>92?1+(p.ocupacion-92)*0.004:1;var egr=Math.round(egrBase/cong);var pGRD=egr*s.indiceCaseMix;var ingGRD=pGRD*s.arancelGRD;var presEj=s.presupuestoBase*(p.ejecucion/100);var cFijo=s.camas*s.costoFijoPorCama;var cPersonal=s.camas*s.costoPersonalBase*(1+p.horasExtra/100*1.5)*(1+p.ausentismo/100*0.7);var cVar=egr*(p.costoInsumos*1000);var aInf=1+(p.inflacion/100);var gTotal=(cFijo+cPersonal+cVar)*aInf;var cDeriv=egr*((100-p.resolutividad)/100)*p.derivacionesRedExterna*1000;var cEquip=p.inversionEquipamiento*1_000_000;var cTotal=gTotal+cDeriv+cEquip;var finTotal=ingGRD+presEj;var deficit=cTotal-finTotal;var defPct=(deficit/presEj)*100;var nuevaDemC=egr*0.2;var nuevaDemQ=egr*0.15;var redLE_C=s.leInicialConsultas*(p.avanceLEConsultas/100);var redLE_Q=s.leInicialQuirurgica*(p.avanceLEQuirurgica/100);var leC=Math.round(s.leInicialConsultas-redLE_C+nuevaDemC);var leQ=Math.round(s.leInicialQuirurgica-redLE_Q+nuevaDemQ);var riesgo=leQ>4500?(leQ-4500)*0.002:leC>10000?(leC-10000)*0.001:0;var ef=Math.min(100,Math.max(0,65-(p.readmision-3.5)*6-(p.estancia-5.5)*4+(p.ocupacion<94?8:-10)+(p.avanceLEQuirurgica/5)+(p.resolutividad-80)*0.3));var cumplGES=Math.min(100,Math.max(75,92-(p.estancia-5)*1.5-(leQ-4000)*0.005+(p.avanceLEQuirurgica-10)*0.2));var gpPct=Math.round(cPersonal/(cTotal||1)*100);return{egresos:egr,deficitPct:+defPct.toFixed(1),leQuirurgica:leQ,leConsultas:leC,cumplimientoGES:Math.round(cumplGES),riesgoSancion:+riesgo.toFixed(2),eficiencia:Math.round(ef),gastoPersonalPct:gpPct};}"
