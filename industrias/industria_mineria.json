  "initState": {"precioCobre":4.0, "ley":0.65, "costoInsumos":22, "consumoAgua":0.5, "costoEnergia":90, "precioMolibdeno":20, "precioOro":1850, "precioPlata":24, "tcrc":80, "consumoAcido":3.5, "fletePuerto":18, "depreciacion":60, "leyCorte":0.25},
  "formulaPrincipal": "function(p, s, ctx) { var prod = s.produccionBase * (p.ley / s.leyCabezaBase); if (p.ley < p.leyCorte) { prod = prod * Math.pow(p.ley / p.leyCorte, 2); } prod = Math.max(1000, prod); var mineral = prod / (p.ley / 100 * s.recuperacion); var ingCu = prod * s.factorLibrasPorTon * p.precioCobre; var ingMo = mineral * s.proporcionMolibdeno * s.recuperacion * s.factorLibrasPorTon * p.precioMolibdeno; var ingAu = mineral * s.proporcionOro * s.recuperacion / s.gramosPorOnza * p.precioOro; var ingAg = mineral * s.proporcionPlata * s.recuperacion / s.gramosPorOnza * p.precioPlata; var ingSub = ingMo + ingAu + ingAg; var ingTotal = ingCu + ingSub; var costoMina = mineral * (p.costoInsumos + p.consumoAcido * s.precioAcido); var costoPlanta = mineral * (p.consumoAgua * s.factorAgua + p.costoEnergia * s.factorEnergia + s.costoPlantaBase); var costoFlete = mineral * p.fletePuerto; var costoTC = prod * p.tcrc; var costoOp = costoMina + costoPlanta + costoFlete + costoTC; var ebitda = (ingTotal - costoOp) / 1_000_000; var costoTotal = costoOp + (p.depreciacion * 1_000_000); var c1 = costoOp / (prod * s.factorLibrasPorTon); var c2 = costoTotal / (prod * s.factorLibrasPorTon); var margen = p.precioCobre - c2; return { produccionCobre: Math.round(prod), ebitda: +ebitda.toFixed(2), costoC1: +c1.toFixed(2), costoC2: +c2.toFixed(2), margenUnitario: +margen.toFixed(2) }; }"
