  "formulaPrincipal": "function(p,s,ctx){var trans=p.trafico*1000*(p.tasaConversion/100)*s.diasAno;var ing=trans*p.ticketPromedio;var mg=ing*(p.margenBrutoPct/100);var cLog=ing*(p.costoLogisticaPct/100);var cMer=ing*(p.mermaPct/100);var ingOn=ing*(p.penetracionOnline/100);var cOn=ingOn*0.12;var cArr=s.tiendas*p.costoArriendo*12*1_000_000;var cMkt=p.gastoMarketing*1_000_000;var cFijo=s.tiendas*s.costoFijoPorTienda;var ebitda=(mg-cLog-cMer-cOn-cArr-cMkt-cFijo)/1_000_000;var vOnPct=p.penetracionOnline;var cInv=Math.max(1,Math.round(7.5-p.tasaConversion*0.15));return{ebitda:+ebitda.toFixed(2),ventasOnlinePct:+vOnPct.toFixed(0),rotacionInventario:cInv};}"
