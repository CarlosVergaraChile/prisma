  "formulaPrincipal": "function(p,s,ctx){var prod=s.hectareas*s.rendimientoBase*(p.rendimiento/100)*(1+p.riegoTecnificado/300);var merma=p.incidenciaPlagas*0.01+p.tasaRechazoPacking/100;var export=prod*(1-merma);var ing=export*1000*p.precioExportacion;var cAgua=prod*p.costoAgua*650*(1-p.riegoTecnificado/250);var cMan=s.hectareas*12*p.costoManoObra*30;var cFlete=export*p.fleteMaritimo;var cFijo=s.hectareas*s.costoFijoPorHa;var cTotal=cAgua+cMan+cFlete+cFijo;var cTotalUSD=cTotal/p.tipoCambio;var premium=p.certificacionGlobalGAP>80?s.premiumCertificacion:1;var ingFinal=ing*premium;var ebitda=(ingFinal-cTotalUSD)/1_000_000;var huella=p.costoAgua*12.5*(1-p.riegoTecnificado/280);return{ebitda:+ebitda.toFixed(2),produccionExportable:Math.round(export),huellaHidrica:+huella.toFixed(1)};}"
