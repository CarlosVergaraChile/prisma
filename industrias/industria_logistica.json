  "initState": {"ocupacionFlota":85,"tarifaFlete":2.8,"precioCombustible":1050,"tasaAtrasos":8,"tasaSiniestralidad":2.5,"costoNeumaticos":0.18,"congestionRuta":15,"precioPeaje":0.12,"ocupacionBodega":78},
  "formulaPrincipal": "function(p,s,ctx){var kmTotal=(s.flotaPropia*p.ocupacionFlota/100+s.flotaSubcontratada*(p.ocupacionFlota-10)/100)*s.kmPorDiaBase*s.diasOp;var ing=kmTotal*p.tarifaFlete;var comb=p.precioCombustible*0.35;var neum=p.costoNeumaticos;var peaje=p.precioPeaje;var mant=0.45;var costoKm=comb+neum+peaje+mant;var costoVar=kmTotal*costoKm;var sini=kmTotal*p.tasaSiniestralidad/100*0.08;var cFijo=(s.flotaPropia+s.flotaSubcontratada)*s.costoFijoPorCamion;var ebitda=(ing-costoVar-cFijo-sini)/1_000_000;var sla=100-p.tasaAtrasos*6-p.congestionRuta*0.2;return{ebitda:+ebitda.toFixed(2),slaCumplimiento:Math.round(sla),costoPorKm:+costoKm.toFixed(0)};}"
}
