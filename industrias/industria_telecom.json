  "initState": {"arpuMovil":9800,"arpuFijo":14500,"churnVoluntario":2.2,"churnInvoluntario":1.5,"capexEspectro":8500,"calidadServicio":94,"penetracionOTT":55,"quejasSubtel":120,"atencionCliente":72},
  "formulaPrincipal": "function(p,s,ctx){var susTotal=s.suscriptoresMoviles+s.suscriptoresFijos;var ingMov=susTotal*p.arpuMovil*12*0.85;var ingFijo=susTotal*(p.arpuFijo||14500)*12*0.15;var ingTotal=ingMov+ingFijo;var churnTotal=((p.churnVoluntario||2.2)+(p.churnInvoluntario||1.5))/100;var susNetos=Math.round(susTotal*(1-churnTotal));var costosOp=susNetos*s.costoOperativoPorSuscriptor;var capex=(p.capexEspectro||8500)*1_000_000;var multaSubtel=p.quejasSubtel>150?(p.quejasSubtel-150)*s.factorMultaSubtel:0;var ebitda=(ingTotal-costosOp-capex-multaSubtel)/1_000_000;var riesgo=Math.min(25,p.quejasSubtel/12);return{ebitda:+ebitda.toFixed(2),suscriptoresNetos:Math.round(susNetos/1_000),riesgoRegulatorio:+riesgo.toFixed(1)};}"
