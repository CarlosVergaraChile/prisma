  "formulaPrincipal": "function(p,s,ctx){var biomasa=s.biomasaInicial*(1-p.mort/100);var vol=biomasa*(p.yield/100);var ing=vol*p.price*1000*p.fx;var cAlim=s.biomasaInicial*p.fcr*s.costoAlimento*1000;var factorTemp=(p.temp||s.temperaturaReferencia)>s.temperaturaReferencia?1+((p.temp||s.temperaturaReferencia)-s.temperaturaReferencia)*s.factorTemperatura:1;var cSan=(s.costoSanitarioBase+p.calig*s.factorCaligus)*1000*factorTemp;var limAntib=p.calig>6?(p.calig-6)*s.factorAntibioticos:0;var riesgoEsc=p.mort>15?(p.mort-15)*s.factorEscapes:0;var cNorm=(limAntib+riesgoEsc)*1000;var otros=s.biomasaInicial*s.otrosCostosUnit*1000;var ebitda=(ing-cAlim-cSan-cNorm-otros)/1_000_000;var fcrBio=p.fcr*(1+p.calig*0.03);var huella=p.fcr*2.1+(p.temp>14?0.3:0);var antib=p.calig*0.02;return{biomasa:Math.round(biomasa),vol:Math.round(vol),ebitda:+ebitda.toFixed(2),fcrBiologico:+fcrBio.toFixed(2),huellaCarbono:+huella.toFixed(2),usoAntibioticos:+antib.toFixed(3)};}"
