  "initState": {"precioSpot":80,"disponibilidadTermico":88,"factorHidrologia":75,"factorPlantaERNC":32,"precioGas":6.5,"precioCarbon":110,"coberturaPPA":70,"tipoCambio":900,"capacidadBaterias":15,"restriccionTransmision":12,"impuestoVerde":5,"costoMantenimientoMayor":4.5},
  "formulaPrincipal": "function(p,s,ctx){var cap=s.capacidadTotalMW;var h=s.horasAno;var gHidro=cap*s.mixHidro*h*(p.factorHidrologia/100);var gTermico=cap*s.mixTermico*h*(p.disponibilidadTermico/100);var gERNC=cap*s.mixERNC*h*(p.factorPlantaERNC/100);var gTotal=gHidro+gTermico+gERNC;var volPPA=gTotal*(p.coberturaPPA/100);var ingPPA=volPPA*s.precioPPA;var volSpot=gTotal-volPPA;var spotEf=p.precioSpot*(1-p.restriccionTransmision/150);var ingSpot=volSpot*spotEf;var cHidro=gHidro*s.costoMWHidro;var cTerm=gTermico*(p.precioGas*0.8+25+p.precioCarbon*0.02);var cERNC=gERNC*s.costoMWERNC;var costo=cHidro+cTerm+cERNC;var ebitda=(ingPPA+ingSpot-costo)/1_000_000;var bat=p.capacidadBaterias*0.012*500000;var impCO2=gTermico*s.factorEmision*p.impuestoVerde*1000;var mant=p.costoMantenimientoMayor*1_000_000;var ebitdaFinal=(ingPPA+ingSpot-costo+bat-impCO2-mant)/1_000_000;var vert=Math.max(0,8-p.capacidadBaterias*0.18);var emCO2=Math.round(gTermico*s.factorEmision)/1_000;return{ebitda:+ebitdaFinal.toFixed(2),vertimientoPct:+vert.toFixed(1),emisionesCO2:+emCO2.toFixed(2)};}"
