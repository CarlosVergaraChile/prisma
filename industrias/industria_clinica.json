  "initState": {"ocupacion":82,"estancia":3.8,"readmision":3.2,"tarifaBase":310,"proporcionISAPRE":45,"costoInsumos":185,"inflacion":4.2,"horasExtra":12,"usoPabellones":78,"inversionEquipamiento":45,"productividadMedico":18},
  "formulaPrincipal": "function(p,s,ctx){var rot=365/Math.max(p.estancia,0.5);var volBase=s.camas*(p.ocupacion/100)*rot;var cong=p.ocupacion>85?1+(p.ocupacion-85)*0.0025:1;var vol=Math.round(volBase/cong);var tIsapre=1.25,tFonasa=0.85,tPartic=1.60,tConven=0.95;var pIsapre=p.proporcionISAPRE/100,pFonasa=0.35,pPartic=0.15,pConven=0.05;var tarifaMedia=p.tarifaBase*(pIsapre*tIsapre+pFonasa*tFonasa+pPartic*tPartic+pConven*tConven)*1000;var ingBruto=vol*tarifaMedia*p.estancia;var cRead=vol*(p.readmision/100)*tarifaMedia*p.estancia*s.factorReadmision;var ingNeto=ingBruto-cRead;var horaspab=s.pabellones*s.diasOp*s.horasBasePabellon*(p.usoPabellones/100);var ingPab=horaspab*s.ingresoPorPabellonUnit;var ingTotal=ingNeto+ingPab;var cVar=vol*(p.costoInsumos*1000);var cPersonal=s.camas*s.costoPersonalBase*(1+p.horasExtra/100*1.5);var cFijo=s.camas*s.costoFijoPorCama+s.pabellones*s.costoFijoPabellon+p.inversionEquipamiento*1_000_000;var aInf=1+(p.inflacion/100);var cTotal=(cVar+cPersonal+cFijo)*aInf;var multaGES=p.estancia>5?s.factorMultaGES*vol*0.02:0;var margen=(ingTotal-cTotal-multaGES)/1_000_000;var cal=Math.min(100,Math.max(0,65-(p.readmision-3)*8-(p.estancia-3.5)*5+(p.ocupacion<93?10:-5)-(p.horasExtra-10)*0.3+(p.inversionEquipamiento-40)*0.05));var cumplGES=Math.min(100,Math.max(75,95-(p.estancia-3.5)*2-(p.readmision-3)*3+(p.usoPabellones-75)*0.1));var gpPct=Math.round(cPersonal/(ingTotal||1)*100);var prod=Math.round(vol/(s.camas*365)*100)/100;return{volumen:vol,margen:+margen.toFixed(2),calidadIndice:Math.round(cal),cumplimientoGES:Math.round(cumplGES),gastoPersonalPct:gpPct,productividad:+prod.toFixed(2)};}"
